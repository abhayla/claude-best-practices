__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
dist/
build/
.env
venv/
.venv/
test-results/
test-evidence/
.pipeline/
.workflows/
.claude/sessions/
.claude/settings.local.json
.claude/*.lock

# Prevent provisioned core/.claude/ patterns from polluting hub-only .claude/
# Hub-only .claude/ files are tracked explicitly; everything else is ignored.
# If you need to add a new hub-only pattern, use `git add -f .claude/path`.
.claude/config/
.claude/sync-manifest.json
CLAUDE.local.md

# Prompt log — contains raw user prompts captured by prompt-logger.sh hook,
# may include secrets/PII. The seed at core/.claude/tasks/prompts.md stays
# tracked so provisioning can copy it into downstream projects.
/.claude/tasks/prompts.md

# Session-governance runtime state (no-overask-guard.sh / prompt-enhance-reminder.sh)
.claude/.enhance-misses.log
.claude/.diagnosis-count
.claude/.keepgoing-count
.claude/.overask-violations.log
.claude/.reviewcard-count
.claude/.verifier-misses.log

# goal-run scratch logs (per docs/goals contracts)
docs/goals/.run/

# Playwright MCP scratch (screenshots, console logs, page/ARIA snapshots) — ephemeral verification artifacts
.playwright-mcp/

# The distributable template MUST be fully tracked despite a global ~/.config/git/ignore ".claude/" rule.
# Without this, NEW core/.claude pattern files (hooks/skills/rules/agents) are silently dropped on commit.
!core/.claude/

# native-governance-hooks runtime state
.claude/.config-changes.log
.claude/.compaction-handoff.md
